# ─────────────────────────────────────────────────────────────────────────────
# Fluid — Environment Variables
# Copy to `.env.local` for local dev. Set all of these in Vercel → Settings →
# Environment Variables for production.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: Docker Compose spins up Postgres on host port 5433.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/calendly_clone"

# Production (Vercel): use Neon — https://neon.tech (free tier, serverless-optimised).
#
#   1. Sign up at neon.tech → New Project → choose region closest to Vercel region
#   2. Dashboard → Connection Details → copy "Connection string"
#      Use the POOLED connection string (ends with ?sslmode=require&pgbouncer=true)
#      if shown, otherwise the direct string is fine — our app uses Neon's own pool.
#   3. Paste it as DATABASE_URL in Vercel → Settings → Environment Variables.
#
# Example Neon connection string:
# DATABASE_URL="postgresql://USER:PASSWORD@ep-XXX.us-east-2.aws.neon.tech/neondb?sslmode=require"
#
# After setting DATABASE_URL on Vercel, run migrations once from your local machine
# pointing at the Neon DB:
#   DATABASE_URL="<neon-url>" npx prisma migrate deploy

# ── Auth.js ───────────────────────────────────────────────────────────────────
# Generate with: npx auth secret  (or: openssl rand -base64 32)
AUTH_SECRET=""

# Production: set to your Vercel deployment URL, e.g. https://fluid.vercel.app
# Vercel sets VERCEL_URL automatically — AUTH_URL must be the canonical domain.
AUTH_URL="https://your-app.vercel.app"

# Vercel sets VERCEL=1 automatically; AUTH_TRUST_HOST is read by our isTrustHost()
# helper in src/lib/auth.ts and does NOT need to be set manually on Vercel.
# Keep it here only for local Docker / self-hosted deployments.
AUTH_TRUST_HOST=true

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Authorised redirect URIs (add both):
#   https://your-app.vercel.app/api/auth/callback/google
#   http://localhost:3000/api/auth/callback/google  (local dev)
# Authorised JavaScript origins:
#   https://your-app.vercel.app
#   http://localhost:3000
# Scopes required (set in OAuth consent screen):
#   openid, email, profile,
#   https://www.googleapis.com/auth/calendar,
#   https://www.googleapis.com/auth/calendar.events
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ── Microsoft Entra ID (optional — “Continue with Microsoft” on signup) ───────
# Azure Portal → App registrations → your app
# Redirect URI: https://your-app.vercel.app/api/auth/callback/microsoft-entra-id
# Omit AUTH_MICROSOFT_ENTRA_ID_ISSUER to allow personal + work accounts (common).
# AUTH_MICROSOFT_ENTRA_ID_ISSUER="https://login.microsoftonline.com/<tenant-id>/v2.0/"
AUTH_MICROSOFT_ENTRA_ID_ID=""
AUTH_MICROSOFT_ENTRA_ID_SECRET=""

# ── Mailtrap SMTP (email — dev + production) ─────────────────────────────────
# Mailtrap is used for all environments. It has two separate products:
#
# 1. EMAIL TESTING (dev / staging) — sandbox that catches all mail, nothing
#    is delivered to real inboxes. Safe to use with any From address.
#    mailtrap.io → Email Testing → Inboxes → your inbox → SMTP Settings tab
#      SMTP_HOST=sandbox.smtp.mailtrap.io
#      SMTP_PORT=587
#      SMTP_USER=<inbox username>
#      SMTP_PASS=<inbox password>
#
# 2. EMAIL SENDING (production) — actually delivers to real inboxes.
#    Requires domain verification (SPF + DKIM) before sending.
#    mailtrap.io → Email Sending → Domains → Add domain → follow DNS steps
#    Once domain is verified:
#    mailtrap.io → Email Sending → SMTP / API → Integration → SMTP
#      SMTP_HOST=smtp.mailtrap.io
#      SMTP_PORT=587
#      SMTP_USER=<sending API token as username>
#      SMTP_PASS=<sending API token as password>
#      SMTP_FROM=Fluid <noreply@yourdomain.com>  ← must be @verified-domain
#
# SMTP_SECURE=false for port 587 (STARTTLS). Use true only for port 465 (SSL).
#
SMTP_HOST="sandbox.smtp.mailtrap.io"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
# From address shown on all outbound emails.
# Dev: any address works (sandbox ignores it).
# Production: must use your Mailtrap-verified domain, e.g. noreply@yourdomain.com
SMTP_FROM="Fluid <noreply@yourdomain.com>"

# ── App branding ──────────────────────────────────────────────────────────────
# Controls the app name shown in emails ("Sign in to Fluid", "via Fluid", etc.)
NEXT_PUBLIC_APP_NAME="Fluid"

# ── App URL ───────────────────────────────────────────────────────────────────
# Used in booking confirmation emails for absolute links (cancel URL, dashboard link).
# Must match AUTH_URL exactly.
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# ── Zoom integration (optional) ───────────────────────────────────────────────
# Zoom Marketplace → Build App → OAuth → User-managed app
# Scopes required: meeting:write:meeting, user:read:user
# Redirect URI: https://your-app.vercel.app/api/zoom/callback
ZOOM_CLIENT_ID=""
ZOOM_CLIENT_SECRET=""

# ── Microsoft Teams integration (optional) ────────────────────────────────────
# Azure Portal → App registrations → New registration
# Redirect URI: https://your-app.vercel.app/api/teams/callback  (type: Web)
# API permissions (delegated): Calendars.ReadWrite, OnlineMeetings.ReadWrite,
#                               offline_access, User.Read
# Note: Teams meeting creation requires a work/school (Entra ID) account.
#       Personal accounts (outlook.com, hotmail.com, live.com) are NOT supported.
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""

# ── Deliverability checklist (production) ────────────────────────────────────
# Before sending to real users, verify all of the following in your DNS and Resend:
#
# 1. Domain verified in Resend → publishes SPF + DKIM records automatically.
#    Go to: resend.com/domains → Add domain → follow DNS instructions.
#
# 2. AUTH_RESEND_FROM must use the verified domain, e.g.:
#    AUTH_RESEND_FROM="Fluid <noreply@yourdomain.com>"
#    (Gmail RSVP buttons require DKIM alignment with the From: domain.)
#
# 3. Add a DMARC record to your DNS (start permissive, tighten later):
#    Name: _dmarc.yourdomain.com
#    Value: v=DMARC1; p=none; rua=mailto:dmarc-reports@yourdomain.com
#
# 4. Register the Resend webhook (above) so bounced addresses are suppressed
#    automatically. Without this, repeated sends to bounced addresses will
#    damage your sender reputation.
#
# 5. Warm your sending domain: ramp volume slowly over 1-2 weeks.
#    Avoid burst-sending to cold lists on day one.
